# AI Provider: 'gemini', 'ollama', 'groq', or 'none' (defaults to 'gemini' if GEMINI_API_KEY is set, else 'none')
AI_PROVIDER=none

# Gemini Settings
GEMINI_API_KEY=

# Groq Settings (Optional - if using Groq API)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# Ollama Settings (Optional - if using local Ollama model)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llama3.2-vision

# Google Sheets Spreadsheets ID (Optional - To sync data directly to a Google Sheet)
# Format: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
GOOGLE_SHEET_ID=

# Database Settings (Defaults to local XAMPP MySQL. Set DB_TYPE=sqlite to use local SQLite)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=school_leads

# Authentication Settings
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
